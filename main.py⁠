import asyncio
import logging
from aiogram import Bot, Dispatcher
from config import config
from handlers import user, relay, admin
from middlewares.throttling import ThrottlingMiddleware

async def main():
    logging.basicConfig(level=logging.INFO)
    
    bot = Bot(token=config.BOT_TOKEN)
    dp = Dispatcher()

    # Middlewares
    dp.message.middleware(ThrottlingMiddleware(rate_limit=config.RATE_LIMIT))

    # Routers
    dp.include_routers(admin.router, user.router, relay.router)

    # Botni ishga tushirish (Webhook yoki Polling)
    try:
        await bot.delete_webhook(drop_pending_updates=True)
        await dp.start_polling(bot)
    finally:
        await bot.session.close()

if __name__ == "__main__":
    asyncio.run(main())